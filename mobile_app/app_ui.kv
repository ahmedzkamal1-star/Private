<LoginScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: "40dp"
        spacing: "30dp"
        md_bg_color: 1, 1, 1, 1

        MDBoxLayout:
            orientation: 'vertical'
            adaptive_height: True
            spacing: "20dp"
            
            # Logo Placeholder
            MDIcon:
                icon: "shield-lock"
                font_size: "100sp"
                pos_hint: {"center_x": .5}
                theme_text_color: "Custom"
                text_color: 0, .7, .85, 1

            MDLabel:
                text: app.f_ar("منصة الدحيح الآمنة")
                font_name: "Arabic"
                halign: "center"
                font_style: "H4"
                bold: True
                theme_text_color: "Primary"
                size_hint_y: None
                height: self.texture_size[1] + dp(10)

            MDLabel:
                text: app.f_ar("سجل دخولك للوصول إلى المحتوى")
                font_name: "Arabic"
                halign: "center"
                font_style: "Subtitle1"
                theme_text_color: "Secondary"
                size_hint_y: None
                height: self.texture_size[1] + dp(10)

        MDBoxLayout:
            orientation: 'vertical'
            spacing: "30dp"
            adaptive_height: True

            MDTextField:
                id: user_code
                hint_text: app.f_ar("الكود الجامعي")
                helper_text: app.f_ar("تأكد من كتابة الكود بشكل صحيح")
                helper_text_mode: "on_error"
                font_name_hint_text: "Arabic"
                mode: "round"
                fill_color_normal: 0.95, 0.95, 0.95, 1
                icon_right: "account-badge"
                write_tab: False
                halign: "right"
                padding: "15dp"
                on_text: self.error = False

            MDTextField:
                id: password
                hint_text: app.f_ar("كلمة المرور")
                helper_text: app.f_ar("كلمة المرور غير صحيحة")
                helper_text_mode: "on_error"
                font_name_hint_text: "Arabic"
                mode: "round"
                fill_color_normal: 0.95, 0.95, 0.95, 1
                icon_right: "key"
                password: True
                write_tab: False
                halign: "right"
                padding: "15dp"
                on_text: self.error = False

        MDRelativeLayout:
            size_hint_y: None
            height: "60dp"
            
            MDRoundFlatButton:
                text: app.f_ar("تسجيل الدخول")
                font_name: "Arabic"
                font_size: "20sp"
                pos_hint: {"center_x": .5, "center_y": .5}
                size_hint_x: 0.9
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                md_bg_color: 0, .7, .85, 1
                on_release: root.do_login(user_code.text, password.text)

        MDBoxLayout:
            adaptive_height: True
            padding: [0, dp(20), 0, 0]
            MDLabel:
                text: app.f_ar("جميع الحقوق محفوظة © 2026")
                font_name: "Arabic"
                halign: "center"
                font_style: "Caption"
                theme_text_color: "Hint"

<DashboardScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.96, 0.97, 0.99, 1

        MDTopAppBar:
            title: app.f_ar("المواد الدراسية")
            font_name: "Arabic"
            right_action_items: [["logout", lambda x: app.root.current == "login"]]
            elevation: 2

        MDScrollView:
            MDList:
                id: courses_list
                # Courses will be injected here
                TwoLineIconListItem:
                    text: app.f_ar("رياضيات 1")
                    font_name: "Arabic"
                    secondary_text: app.f_ar("د. علي - 3 دروس")
                    IconLeftWidget:
                        icon: "book-open-page-variant"
